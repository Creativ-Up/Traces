index ca1a3c7..83e01ab 100755
--- a/src/main.rs
+++ b/src/main.rs
@@ -99,9 +99,19 @@ async fn transcript_route(
     })
 }
 
-#[post("/testimony?<a>", format = "plain", data = "<data>")]
-fn new_testimony_route(a: usize, data: String) -> Result<Json<Testimonies>, ErrorResponse> {
-    Testimonies::new_testimony(a as i64, data)
+// XXX[back] `l` (location_id) is a new, optional query param: the id of the recording
+// machine's physical location, stamped by the client from its own config (not visitor
+// input). See traces client repo, src/components/Testimony.jsx and
+// data/mock-api-responses.js XXX[back] on `location`/LOCATION_IDS. The client does not
+// send it yet (src/controllers/API.js#pushTestimony has no such param); until it does,
+// this defaults to None and existing/new rows alike get location_id: null.
+#[post("/testimony?<a>&<l>", format = "plain", data = "<data>")]
+fn new_testimony_route(
+    a: usize,
+    l: Option<String>,
+    data: String,
+) -> Result<Json<Testimonies>, ErrorResponse> {
+    Testimonies::new_testimony(a as i64, data, l)
         .map(Json)
         .map_err(|e| ErrorResponse {
             error_msg: format!("{e:?}"),
